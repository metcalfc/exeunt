[Unit]
Description=Exeunt Autoscaler - GitHub Actions webhook-based runner provisioner
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=exedev
ExecStart=/usr/local/bin/exeunt-autoscaler
Restart=on-failure
RestartSec=5
EnvironmentFile=/etc/exeunt-autoscaler/env
StateDirectory=exeunt-autoscaler

NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/var/lib/exeunt-autoscaler /home/exedev/.config

[Install]
WantedBy=multi-user.target
